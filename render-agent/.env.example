# ─── Server connection ───────────────────────────────
API_BASE_URL=https://your-server.com
AGENT_API_KEY=your-agent-api-key-from-admin-ui

# ─── Polling ─────────────────────────────────────────
POLL_INTERVAL_MS=5000
HEARTBEAT_INTERVAL_MS=30000

# ─── Working directory ───────────────────────────────
WORK_DIR=./work

# ─── After Effects ───────────────────────────────────
AE_PATH=C:\Program Files\Adobe\Adobe After Effects 2024\Support Files\afterfx.exe
MOCK_AE=false

# ─── S3 / MinIO ─────────────────────────────────────
S3_ENDPOINT=https://your-s3-endpoint.com
S3_REGION=us-east-1
S3_BUCKET=ae-render
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─── ElevenLabs TTS (optional) ──────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ─── FFmpeg ──────────────────────────────────────────
FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
